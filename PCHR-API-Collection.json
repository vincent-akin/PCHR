    {
      "name": "Patients",
      "description": "Patient management CRUD operations",
      "item": [
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"dateOfBirth\": \"1990-01-15\",\n  \"gender\": \"male\",\n  \"phone\": \"+2347012345678\",\n  \"email\": \"john.doe@email.com\",\n  \"address\": {\n    \"street\": \"123 Main Street\",\n    \"city\": \"Lagos\",\n    \"state\": \"Lagos\",\n    \"country\": \"Nigeria\"\n  },\n  \"bloodGroup\": \"O+\",\n  \"allergies\": [\"Penicillin\", \"Peanuts\"],\n  \"hospitalId\": \"HOSP001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/patients",
              "host": ["{{base_url}}"],
              "path": ["patients"]
            },
            "description": "Create a new patient record"
          },
          "response": []
        },
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["patients"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search by name, phone, or hospital ID",
                  "disabled": true
                },
                {
                  "key": "bloodGroup",
                  "value": "",
                  "description": "Filter by blood group (A+, A-, B+, B-, O+, O-, AB+, AB-)",
                  "disabled": true
                },
                {
                  "key": "gender",
                  "value": "",
                  "description": "Filter by gender (male, female, other)",
                  "disabled": true
                }
              ]
            },
            "description": "List patients with pagination and filters"
          },
          "response": []
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients/{{patientId}}",
              "host": ["{{base_url}}"],
              "path": ["patients", "{{patientId}}"]
            },
            "description": "Get patient details by ID"
          },
          "response": []
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+2347098765432\",\n  \"email\": \"john.updated@email.com\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/patients/{{patientId}}",
              "host": ["{{base_url}}"],
              "path": ["patients", "{{patientId}}"]
            },
            "description": "Update patient information"
          },
          "response": []
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients/{{patientId}}",
              "host": ["{{base_url}}"],
              "path": ["patients", "{{patientId}}"]
            },
            "description": "Soft delete patient (Admin only)"
          },
          "response": []
        },
        {
          "name": "Get Patient Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients/stats",
              "host": ["{{base_url}}"],
              "path": ["patients", "stats"]
            },
            "description": "Get patient demographic statistics"
          },
          "response": []
        }
      ]
