    {
      "name": "Medical Records",
      "description": "Medical records management",
      "item": [
        {
          "name": "Create Medical Record",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"type\": \"consultation\",\n  \"title\": \"Initial Cardiology Consultation\",\n  \"notes\": \"Patient reports chest pain when exercising. BP elevated.\",\n  \"vitalSigns\": {\n    \"bloodPressure\": {\n      \"systolic\": 135,\n      \"diastolic\": 85\n    },\n    \"heartRate\": 78,\n    \"temperature\": 36.8,\n    \"weight\": 75.5,\n    \"height\": 175\n  },\n  \"diagnosis\": [\n    {\n      \"code\": \"I10\",\n      \"description\": \"Essential hypertension\",\n      \"isPrimary\": true\n    }\n  ],\n  \"medications\": [\n    {\n      \"name\": \"Lisinopril\",\n      \"dosage\": \"10mg\",\n      \"frequency\": \"Once daily\",\n      \"instructions\": \"Take in the morning with food\"\n    }\n  ],\n  \"followUpRequired\": true,\n  \"followUpDate\": \"2026-04-15\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/records",
              "host": ["{{base_url}}"],
              "path": ["records"]
            },
            "description": "Create a new medical record"
          },
          "response": []
        },
        {
          "name": "Get Patient Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/records/patient/{{patientId}}?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["records", "patient", "{{patientId}}"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "type",
                  "value": "",
                  "description": "Filter by record type",
                  "disabled": true
                }
              ]
            },
            "description": "Get all medical records for a patient"
          },
          "response": []
        },
        {
          "name": "Get Record Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/records/stats",
              "host": ["{{base_url}}"],
              "path": ["records", "stats"]
            },
            "description": "Get record statistics (by type, monthly trends, top doctors)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transfers",
      "description": "Inter-hospital record transfers",
      "item": [
        {
          "name": "Create Transfer Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"toTenant\": \"{{destinationTenantId}}\",\n  \"type\": \"full_record\",\n  \"requestNotes\": \"Request for second opinion\",\n  \"patientConsent\": {\n    \"obtained\": true,\n    \"consentMethod\": \"digital\"\n  },\n  \"purpose\": \"second_opinion\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers",
              "host": ["{{base_url}}"],
              "path": ["transfers"]
            },
            "description": "Request to transfer patient records to another institution"
          },
          "response": []
        },
        {
          "name": "List Transfers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/transfers?status=pending",
              "host": ["{{base_url}}"],
              "path": ["transfers"],
              "query": [
                {
                  "key": "status",
                  "value": "pending",
                  "description": "Filter by status (pending, approved, rejected, completed)"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "List transfers with filters"
          },
          "response": []
        },
        {
          "name": "Approve Transfer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Approved for specialist review\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/transfers/{{transferId}}/approve",
              "host": ["{{base_url}}"],
              "path": ["transfers", "{{transferId}}", "approve"]
            },
            "description": "Approve a pending transfer request (destination tenant only)"
          },
          "response": []
        },
        {
          "name": "Complete Transfer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/transfers/{{transferId}}/complete",
              "host": ["{{base_url}}"],
              "path": ["transfers", "{{transferId}}", "complete"]
            },
            "description": "Complete transfer and send records (source tenant only)"
          },
          "response": []
        },
        {
          "name": "Get Transfer Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/transfers/stats",
              "host": ["{{base_url}}"],
              "path": ["transfers", "stats"]
            },
            "description": "Get transfer statistics (pending, completed, avg processing time)"
          },
          "response": []
        }
      ]
    },
