# Server Configuration
NODE_ENV=development
PORT=8000

# Database Configuration
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pchr

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=pchr-backend
JWT_AUDIENCE=pchr-clients

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=20971520
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf,application/dicom

# Cloud Storage (AWS S3 example)
CLOUD_STORAGE_PROVIDER=aws
CLOUD_STORAGE_BUCKET=your-bucket-name
CLOUD_STORAGE_REGION=us-east-1
CLOUD_STORAGE_ACCESS_KEY_ID=your-access-key
CLOUD_STORAGE_SECRET_ACCESS_KEY=your-secret-key

# Security
BCRYPT_ROUNDS=10
CORS_ORIGIN=*
SESSION_SECRET=change-this-in-production

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# MongoDB Options
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_CONNECT_TIMEOUT_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_HEARTBEAT_FREQUENCY_MS=10000
MONGODB_RETRY_WRITES=true
MONGODB_RETRY_READS=true