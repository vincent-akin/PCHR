{
  "name": "pchr-backend",
  "version": "1.0.0",
  "description": "Patient Clinical Health Record Platform Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:models": "node scripts/test-models.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincent-akin/PCHR.git"
  },
  "keywords": [
    "healthcare",
    "emr",
    "ehr",
    "medical-records"
  ],
  "author": "vincent-akin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vincent-akin/PCHR/issues"
  },
  "homepage": "https://github.com/vincent-akin/PCHR#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@ljharb/tsconfig": "^0.3.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  }
}
